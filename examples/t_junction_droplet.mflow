          {
            "id": "port-tj-main-in",
            "name": "main_inlet",
            "position": { "x": -400.0, "y": 0.0 },
            "direction": "in",
            "connected_to": "ch-oil-main"
          },
          {
            "id": "port-tj-side",
            "name": "side_inlet",
            "position": { "x": 0.0, "y": -300.0 },
            "direction": "in",
            "connected_to": "ch-water-side"
          },
          {
            "id": "port-tj-out",
            "name": "outlet",
            "position": { "x": 400.0, "y": 0.0 },
