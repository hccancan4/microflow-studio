        "label": "T-Junction",
        "position": { "x": 2500.0, "y": 2000.0 },
        "rotation": 0.0,
        "params": {
          "main_width": 200.0,
          "side_width": 100.0,
          "depth": 50.0,
          "junction_angle": 90.0
        },
