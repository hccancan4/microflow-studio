  "simulation": {
    "level": "analytical",
    "fluid": {
      "name": "water",
      "density": 997.0,
      "viscosity": 0.000890
    },
    "boundary_conditions": [
      {
        "port_id": "port-main-inlet-out",
        "type": "flow_rate",
        "value": 10.0,
        "unit": "ul_min"
      },
      {
        "port_id": "port-main-outlet-in",
        "type": "pressure",
        "value": 0.0,
        "unit": "pa"
      }
    ],
    "notes": "5 identical parallel channels, 150×50 μm, 5 mm long. Symmetric manifold ensures equal distribution: Q_each = 2 μL/min. R_channel = 12μL/(wh³(1-0.63h/w)) × L. For equal distribution: R_distribution_manifold << R_channel. Check: R_ch per channel, then parallel combination = R_ch/5. Total flow velocity in each: U = Q/(wh) = 2μL/min / (150×50μm²) ≈ 4.44 mm/s. Re ≈ 0.33 (very laminar)."
  },
  "script": {
    "language": "lua",
    "content": "-- Parallel Channel Array Analysis\n-- Verifies equal flow distribution and computes per-channel properties\n\nlocal n_channels = 5\nlocal Q_total = 10       -- μL/min\nlocal w = 150            -- μm\nlocal h = 50             -- μm\nlocal L_ch = 5000        -- μm (5 mm)\nlocal mu = 0.000890      -- Pa·s (water 25°C)\nlocal rho = 997          -- kg/m³\n\n-- Per-channel flow rate (symmetric manifold → equal split)\nlocal Q_each = Q_total / n_channels\nmf.log(string.format(\"Per-channel flow rate: %.2f μL/min\", Q_each))\n\n-- Hydraulic resistance (Mortensen aspect-ratio correction)\nlocal w_SI = w * 1e-6\nlocal h_SI = h * 1e-6\nlocal L_SI = L_ch * 1e-6\nlocal correction = 1 - 0.630 * (h_SI / w_SI)\nlocal R_ch = 12 * mu * L_SI / (w_SI * h_SI^3 * correction)\nmf.log(string.format(\"Channel resistance: %.3e Pa·s/m³\", R_ch))\nmf.log(string.format(\"Parallel combination (5x): %.3e Pa·s/m³\", R_ch / n_channels))\n\n-- Pressure drop across channels\nlocal Q_SI = Q_each * 1.667e-11   -- m³/s\nlocal dP = Q_SI * R_ch\nmf.log(string.format(\"Pressure drop per channel: %.1f Pa\", dP))\n\n-- Mean velocity\nlocal A = w_SI * h_SI\nlocal U = Q_SI / A\nmf.log(string.format(\"Mean velocity: %.2f mm/s\", U * 1000))\n\n-- Reynolds number\nlocal Dh = 2 * w_SI * h_SI / (w_SI + h_SI)\nlocal Re = rho * U * Dh / mu\nmf.log(string.format(\"Re = %.4f (deeply laminar)\", Re))\n\n-- Manifold sizing recommendation\n-- For uniform distribution: R_manifold < R_channel / 10\nlocal R_manifold_max = R_ch / 10\nmf.log(string.format(\"\\nManifold design: R_manifold < %.3e Pa·s/m³\", R_manifold_max))\nmf.log(\"→ Manifold channel should be at least 3-4x wider than parallel channels\")\n\nlocal result = mf.simulate({ fluid = \"water\" })\nmf.log(string.format(\"\\nTotal ΔP: %.1f Pa\", result.total_pressure_drop_pa))\n",
    "last_run_at": null,
    "last_run_output": null
  }
}
