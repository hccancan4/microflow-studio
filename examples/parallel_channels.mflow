{
  "mflow_version": 1,
  "metadata": {
    "name": "Parallel Channel Array (5 channels)",
    "description": "Five parallel channels fed by a symmetric distribution manifold and collected by a symmetric output manifold. All channels identical: 150 μm wide, 50 μm deep, 5 mm long. Equal flow distribution achieved by matching manifold geometry. Total flow: 10 μL/min → 2 μL/min per channel.",
    "author": "MicroFlow Studio Examples",
    "created_at": "2025-09-01T10:00:00Z",
    "updated_at": "2025-09-01T10:00:00Z",
    "tags": ["parallel", "manifold", "flow-distribution", "array"],
    "units": "um"
  },
